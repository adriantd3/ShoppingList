{
  "info": {
    "_postman_id": "f0f0ed3a-7f31-4d6e-86d1-0e89bf5c9ca9",
    "name": "ShoppingList Python API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "Native Postman collection with automatic JWT capture and reuse across protected endpoints."
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{jwt_token}}",
        "type": "string"
      }
    ]
  },
  "variable": [
    { "key": "baseUrl", "value": "http://127.0.0.1:8000" },
    { "key": "jwt_token", "value": "" },
    { "key": "list_id", "value": "list-1" },
    { "key": "item_id", "value": "item-1" },
    { "key": "share_link_id", "value": "link-1" },
    { "key": "share_token", "value": "" }
  ],
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "const path = pm.request.url.getPath();",
          "const isPublic = path.endsWith('/auth/login') || path.endsWith('/health');",
          "if (isPublic) {",
          "  pm.request.auth = { type: 'noauth' };",
          "  pm.request.headers.remove('Authorization');",
          "  return;",
          "}",
          "const token = pm.collectionVariables.get('jwt_token');",
          "if (token) {",
          "  pm.request.headers.upsert({ key: 'Authorization', value: `Bearer ${token}` });",
          "} else {",
          "  pm.request.headers.remove('Authorization');",
          "}"
        ]
      }
    }
  ],
  "item": [
    {
      "name": "Health",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/v1/health",
          "host": ["{{baseUrl}}"],
          "path": ["api", "v1", "health"]
        }
      }
    },
    {
      "name": "Auth",
      "item": [
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Login returns access token', function () {",
                  "  const data = pm.response.json();",
                  "  pm.expect(data).to.have.property('access_token');",
                  "  pm.expect(data.access_token).to.be.a('string').and.not.empty;",
                  "});",
                  "const data = pm.response.json();",
                  "if (data && data.access_token) {",
                  "  pm.collectionVariables.set('jwt_token', data.access_token);",
                  "  pm.environment.set('jwt_token', data.access_token);",
                  "}",
                  "pm.test('jwt_token is stored', function () {",
                  "  pm.expect(pm.collectionVariables.get('jwt_token')).to.be.a('string').and.not.empty;",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"demo@shoppinglist.dev\",\n  \"password\": \"DemoPass123!\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "auth", "login"]
            }
          }
        }
      ]
    },
