APP_ENV=local
APP_DEBUG=false
APP_HOST=127.0.0.1
APP_PORT=8000
API_V1_PREFIX=/v1
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/shoppinglist
JWT_SECRET_KEY=replace-with-at-least-32-characters
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
CORS_ALLOW_ORIGINS=http://localhost:19006
TRUSTED_HOSTS=localhost,127.0.0.1
ENABLE_DOCS=true
LOG_LEVEL=INFO
